# ─────────────────────────────────────────────────────────────────
# RAM-IA — .gitignore
# ─────────────────────────────────────────────────────────────────

# ── Datos sensibles (no subir al repositorio) ────────────────────
files/
*.xlsx
*.xls
*.csv

# ── Entornos virtuales ───────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env
.envrc

# ── Python — bytecode y caché ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Jupyter Notebook ─────────────────────────────────────────────
.ipynb_checkpoints/

# ── Streamlit ────────────────────────────────────────────────────
.streamlit/secrets.toml
.streamlit/cache/

# ── Distribución y empaquetado ───────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Tests y cobertura ────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ── Herramientas de tipo y caché de linters ──────────────────────
.mypy_cache/
.ruff_cache/

# ── IDEs ─────────────────────────────────────────────────────────
# VSCode
.vscode/

# PyCharm / JetBrains
.idea/

# Spyder
.spyderproject
.spyproject

# ── Sistema operativo ────────────────────────────────────────────
# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# ── Archivos temporales del proyecto ─────────────────────────────
prueba.txt
*.tmp
*.log
